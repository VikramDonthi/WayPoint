<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Top Rider Profile Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_card"
        android:orientation="vertical"
        android:padding="20dp"
        android:elevation="2dp">

        <TextView
            android:id="@+id/tvRiderName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rider Name"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvRiderPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mobile: --"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvShiftStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OFF DUTY — INACTIVE"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="14dp" />
    </LinearLayout>

    <!-- Shift Live Stats Card (Distance & Telemetry) -->
    <LinearLayout
        android:id="@+id/cardTrackingIndicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_card"
        android:orientation="vertical"
        android:padding="18dp"
        android:layout_marginTop="16dp"
        android:elevation="2dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CURRENT SHIFT DISTANCE"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"/>

        <TextView
            android:id="@+id/tvShiftDistance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.00 km"
            android:textColor="@color/accent_cyan"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● Live Location &amp; Shift Tracking Active"
            android:textColor="@color/accent_green"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="10dp"/>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBarShift"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="24dp"
        android:visibility="gone"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Shift Action Button -->
    <Button
        android:id="@+id/btnToggleShift"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Start Shift"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="@color/accent_cyan"/>

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sign Out"
        android:textColor="@color/accent_red"
        android:layout_marginTop="12dp"
        style="@style/Widget.MaterialComponents.Button.TextButton"/>

</LinearLayout>
