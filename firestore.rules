rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // ── DEV RULES: Allow read & write for any signed-in user ──────────────────
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
